# =============================================================================
# AURA EDUCACIONAL — VARIÁVEIS DE AMBIENTE
# IMPORTANTE: Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env — apenas .env.example
# =============================================================================

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME="Aura Educacional"
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GOOGLE_CLIENT_ID=XXXXX.apps.googleusercontent.com
API_PORT=3001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://*.pages.dev
COOKIE_DOMAIN=

# ─── BANCO DE DADOS ───────────────────────────────────────────────────────────
# ATENÇÃO: Use senha forte em produção (min. 32 chars, aleatória)
POSTGRES_DB=aura_educacional
POSTGRES_USER=aura
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
DATABASE_URL="postgresql://aura:TROQUE_POR_SENHA_FORTE_AQUI@localhost:5432/aura_educacional"

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_REDIS_AQUI
REDIS_URL="redis://:TROQUE_POR_SENHA_REDIS_AQUI@localhost:6379"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GERE_UM_SECRET_ALEATORIO_DE_64_BYTES_AQUI
JWT_REFRESH_SECRET=GERE_OUTRO_SECRET_DIFERENTE_AQUI

# ─── NEXTAUTH (para o frontend Next.js) ──────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=GERE_UM_SECRET_NEXTAUTH_AQUI
NEXTAUTH_URL=http://localhost:3000

# ─── EMAIL (SMTP) ─────────────────────────────────────────────────────────────
# Opções recomendadas: Resend (resend.com) ou SES (Amazon)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=SUA_API_KEY_RESEND_AQUI
EMAIL_FROM="Aura Educacional <noreply@aura-educacional.com.br>"

# ─── STORAGE (MinIO / S3) ─────────────────────────────────────────────────────
MINIO_ROOT_USER=aura_admin
MINIO_ROOT_PASSWORD=TROQUE_POR_SENHA_MINIO_AQUI
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET_COURSES=aura-courses
MINIO_BUCKET_CERTIFICATES=aura-certificates
MINIO_BUCKET_AVATARS=aura-avatars

# ─── PAGAMENTOS (Stripe) ──────────────────────────────────────────────────────
# Use keys de TESTE durante desenvolvimento
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXX
STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXX

# Planos Stripe (criar no dashboard stripe.com)
STRIPE_PRICE_PRO_MONTHLY=price_XXXXX
STRIPE_PRICE_ELITE_MONTHLY=price_XXXXX

# ─── OAUTH (login social) ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=XXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXX

# ─── SSL ─────────────────────────────────────────────────────────────────────
SSL_EMAIL=contato@aura-educacional.com.br

# ─── PGADMIN (apenas dev) ─────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@aura.local
PGADMIN_PASSWORD=admin

# ─── LOGS ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info   # debug | info | warn | error
